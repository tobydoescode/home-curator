{
  "name": "home-curator-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "npm run gen:api:local && tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text",
    "gen:api": "openapi-typescript http://localhost:8099/openapi.json -o src/api/generated.ts",
    "gen:api:local": "cd ../backend && uv run python -c \"import json; from home_curator.main import app; print(json.dumps(app.openapi()))\" > /tmp/home-curator-openapi.json && cd ../frontend && openapi-typescript /tmp/home-curator-openapi.json -o src/api/generated.ts"
  },
  "dependencies": {
    "@mantine/core": "^9.0.0",
    "@mantine/hooks": "^9.0.0",
    "@mantine/modals": "^9.0.0",
    "@mantine/notifications": "^9.0.0",
    "@tabler/icons-react": "^3.11.0",
    "@tanstack/react-query": "^5.51.0",
    "@tanstack/react-table": "^8.19.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "7.14.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "jsdom": "^29.0.0",
    "msw": "^2.4.0",
    "openapi-typescript": "^7.4.0",
    "postcss": "^8.4.0",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
